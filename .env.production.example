# ==================================================================
#  RemotelyYours Production Environment Variables
#  Copy to .env and fill in real values before deploying
# ==================================================================

# --- Required ---
DATABASE_URL=postgresql://user:pass@host:5432/remotelyyours_production
JWT_SECRET=<generate-with: openssl rand -hex 64>
RAILS_ENV=production
RAILS_MASTER_KEY=<from-config/master.key>
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# --- Frontend ---
FRONTEND_URL=https://app.remotelyyours.com
APP_HOST=remotelyyours.com

# --- Redis (for Sidekiq) ---
REDIS_URL=redis://localhost:6379/0

# --- AI Features ---
OPENAI_API_KEY=sk-...

# --- Job Ingestion ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# --- Razorpay Payments ---
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=

# --- Email (SendGrid) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.<your-sendgrid-api-key>
MAILER_FROM=hello@remotelyyours.com

# --- Puma ---
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5
PORT=3001
