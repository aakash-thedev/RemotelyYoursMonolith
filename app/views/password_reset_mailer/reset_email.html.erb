<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #FAF6EF; margin: 0; padding: 40px 20px; }
    .container { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 16px; padding: 40px; box-shadow: 0 1px 4px rgba(44,26,14,0.08); }
    h1 { color: #2C1A0E; font-size: 24px; margin: 0 0 16px; }
    p { color: #4A3728; font-size: 14px; line-height: 1.6; margin: 0 0 16px; }
    .btn { display: inline-block; background: #C9603A; color: #fff; text-decoration: none; padding: 12px 32px; border-radius: 100px; font-weight: 600; font-size: 14px; }
    .muted { color: #8B6E5A; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Reset your password</h1>
    <p>Hi <%= @user.full_name.split(" ").first %>,</p>
    <p>We received a request to reset the password for your RemotelyYours account. Click the button below to set a new password:</p>
    <p style="text-align: center; margin: 32px 0;">
      <a href="<%= @reset_url %>" class="btn">Reset Password</a>
    </p>
    <p class="muted">This link expires in 2 hours. If you didn't request a password reset, you can safely ignore this email.</p>
    <p class="muted">— The RemotelyYours Team</p>
  </div>
</body>
</html>
